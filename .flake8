[flake8]
max-line-length = 88
exclude = .git,__pycache__,venv,alembic/versions/*,src/api*,src/services*,src/utils*,src/schemas*
ignore = E203, W503, E501
per-file-ignores =
    __init__.py: F401
    src/models/models.py: E712
    alembic/*: E711,E712,F401
    src/*: F401,F541,E402,E722,E226,F811,F841,W291
